        "# ==========================================\n",
        "# Lab 4: Data Quality Assessment & Preprocessing\n",
        "# ARTI 308 - Machine Learning\n",
        "# ==========================================\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.preprocessing import MinMaxScaler, StandardScaler\n",
        "from sklearn.decomposition import PCA\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "sns.set_style('whitegrid')\n",
        "plt.rcParams['figure.figsize'] = (12, 6)\n",
        "\n",
        "print(\"=\"*80)\n",
        "print(\"LAB 4: DATA QUALITY ASSESSMENT & PREPROCESSING\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# ==========================================\n",
        "# LOAD DATASET\n",
        "# ==========================================\n",
        "print(\"\\n📂 Loading Dataset...\")\n",
        "df = pd.read_csv('diabetes_prediction_dataset.csv')\n",
        "print(f\"✅ Dataset loaded: {df.shape[0]:,} rows × {df.shape[1]} columns\\n\")\n",
        "\n",
        "# ==========================================\n",
        "# TASK 1: DATA QUALITY ASSESSMENT\n",
        "# ==========================================\n",
        "print(\"=\"*80)\n",
        "print(\"TASK 1: DATA QUALITY ASSESSMENT\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "print(\"\\n1️⃣ Missing Values Check:\")\n",
        "missing = df.isnull().sum()\n",
        "print(missing)\n",
        "print(f\"Total missing values: {missing.sum()}\")\n",
        "\n",
        "print(\"\\n2️⃣ Duplicate Rows Check:\")\n",
        "duplicates = df.duplicated().sum()\n",
        "print(f\"Number of duplicates: {duplicates:,}\")\n",
        "if duplicates > 0:\n",
        "    df = df.drop_duplicates()\n",
        "    print(f\"✅ Removed duplicates. New shape: {df.shape}\")\n",
        "\n",
        "print(\"\\n3️⃣ Data Types:\")\n",
        "print(df.dtypes)\n",
        "\n",
        "print(\"\\n4️⃣ Basic Statistics:\")\n",
        "print(df.describe())\n",
        "\n",
        "print(\"\\n5️⃣ Data Range Issues:\")\n",
        "numerical_cols = df.select_dtypes(include=[np.number]).columns\n",
        "for col in numerical_cols:\n",
        "    print(f\"\\n{col}:\")\n",
        "    print(f\"  Range: [{df[col].min():.2f}, {df[col].max():.2f}]\")\n",
        "    print(f\"  Mean: {df[col].mean():.2f}, Median: {df[col].median():.2f}\")\n",
        "\n",
        "# ==========================================\n",
        "# TASK 2: HANDLE MISSING VALUES\n",
        "# ==========================================\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"TASK 2: HANDLING MISSING VALUES\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "print(\"\\nIntroducing artificial missing values for demonstration...\")\n",
        "df_copy = df.copy()\n",
        "np.random.seed(42)\n",
        "mask = np.random.rand(len(df_copy)) < 0.05\n",
        "df_copy.loc[mask, 'bmi'] = np.nan\n",
        "mask2 = np.random.rand(len(df_copy)) < 0.03\n",
        "df_copy.loc[mask2, 'blood_glucose_level'] = np.nan\n",
        "\n",
        "print(f\"\\nMissing values introduced:\")\n",
        "print(df_copy.isnull().sum())\n",
        "\n",
        "print(\"\\n📊 Visualizing Missing Values:\")\n",
        "plt.figure(figsize=(10, 6))\n",
        "sns.heatmap(df_copy.isnull(), cbar=True, cmap='YlOrRd', yticklabels=False)\n",
        "plt.title('Missing Values Heatmap', fontsize=16, fontweight='bold')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n🔧 Applying Missing Value Strategy: MEDIAN IMPUTATION\")\n",
        "print(\"Reason: BMI and glucose have outliers, median is more robust than mean\")\n",
        "\n",
        "for col in df_copy.columns:\n",
        "    if df_copy[col].isnull().sum() > 0:\n",
        "        if df_copy[col].dtype in [np.float64, np.int64]:\n",
        "            median_val = df_copy[col].median()\n",
        "            df_copy[col].fillna(median_val, inplace=True)\n",
        "            print(f\"  Filled {col} with median: {median_val:.2f}\")\n",
        "\n",
        "print(\"\\n✅ Missing values after imputation:\")\n",
        "print(df_copy.isnull().sum())\n",
        "\n",
        "df = df_copy.copy()\n",
        "\n",
        "# ==========================================\n",
        "# TASK 3: HANDLE OUTLIERS USING IQR\n",
        "# ==========================================\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"TASK 3: DETECTING AND HANDLING OUTLIERS (IQR METHOD)\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "def detect_outliers_iqr(data, column):\n",
        "    Q1 = data[column].quantile(0.25)\n",
        "    Q3 = data[column].quantile(0.75)\n",
        "    IQR = Q3 - Q1\n",
        "    lower_bound = Q1 - 1.5 * IQR\n",
        "    upper_bound = Q3 + 1.5 * IQR\n",
        "    outliers = data[(data[column] < lower_bound) | (data[column] > upper_bound)]\n",
        "    return outliers, lower_bound, upper_bound, Q1, Q3, IQR\n",
        "\n",
        "outlier_cols = ['age', 'bmi', 'HbA1c_level', 'blood_glucose_level']\n",
        "\n",
        "print(\"\\n📊 Outlier Detection Summary:\")\n",
        "outlier_stats = []\n",
        "\n",
        "for col in outlier_cols:\n",
        "    outliers, lower, upper, Q1, Q3, IQR = detect_outliers_iqr(df, col)\n",
        "    outlier_stats.append({\n",
        "        'Column': col,\n",
        "        'Q1': Q1,\n",
        "        'Q3': Q3,\n",
        "        'IQR': IQR,\n",
        "        'Lower Bound': lower,\n",
        "        'Upper Bound': upper,\n",
        "        'Outliers Count': len(outliers),\n",
        "        'Outliers %': (len(outliers)/len(df))*100\n",
        "    })\n",
        "\n",
        "outlier_df = pd.DataFrame(outlier_stats)\n",
        "print(outlier_df.to_string(index=False))\n",
        "\n",
        "print(\"\\n📦 Box Plots Before Outlier Removal:\")\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "axes = axes.ravel()\n",
        "\n",
        "for idx, col in enumerate(outlier_cols):\n",
        "    df.boxplot(column=col, ax=axes[idx])\n",
        "    axes[idx].set_title(f'Box Plot: {col}', fontsize=12, fontweight='bold')\n",
        "    axes[idx].set_ylabel(col)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n🔧 Applying Outlier Removal (IQR Method):\")\n",
        "df_no_outliers = df.copy()\n",
        "\n",
        "for col in outlier_cols:\n",
        "    outliers, lower, upper, Q1, Q3, IQR = detect_outliers_iqr(df_no_outliers, col)\n",
        "    before_count = len(df_no_outliers)\n",
        "    df_no_outliers = df_no_outliers[(df_no_outliers[col] >= lower) & (df_no_outliers[col] <= upper)]\n",
        "    after_count = len(df_no_outliers)\n",
        "    removed = before_count - after_count\n",
        "    if removed > 0:\n",
        "        print(f\"  {col}: Removed {removed:,} outliers\")\n",
        "\n",
        "print(f\"\\n✅ Dataset shape after outlier removal: {df_no_outliers.shape}\")\n",
        "print(f\"Total rows removed: {len(df) - len(df_no_outliers):,}\")\n",
        "\n",
        "print(\"\\n📦 Box Plots After Outlier Removal:\")\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "axes = axes.ravel()\n",
        "\n",
        "for idx, col in enumerate(outlier_cols):\n",
        "    df_no_outliers.boxplot(column=col, ax=axes[idx])\n",
        "    axes[idx].set_title(f'Box Plot (After): {col}', fontsize=12, fontweight='bold')\n",
        "    axes[idx].set_ylabel(col)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "df = df_no_outliers.copy()\n",
        "\n",
        "# ==========================================\n",
        "# TASK 4: NORMALIZATION\n",
        "# ==========================================\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"TASK 4: FEATURE NORMALIZATION\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "numerical_features = ['age', 'bmi', 'HbA1c_level', 'blood_glucose_level']\n",
        "df_norm = df[numerical_features].copy()\n",
        "\n",
        "print(\"\\n📊 Original Data Statistics:\")\n",
        "print(df_norm.describe())\n",
        "\n",
        "# Min-Max Normalization\n",
        "print(\"\\n\" + \"-\"*80)\n",
        "print(\"4.1 MIN-MAX NORMALIZATION (Range: 0 to 1)\")\n",
        "print(\"-\"*80)\n",
        "\n",
        "scaler_minmax = MinMaxScaler()\n",
        "df_minmax = pd.DataFrame(\n",
        "    scaler_minmax.fit_transform(df_norm),\n",
        "    columns=[f'{col}_minmax' for col in numerical_features]\n",
        ")\n",
        "\n",
        "print(\"\\n✅ Min-Max Normalized Data:\")\n",
        "print(df_minmax.describe())\n",
        "\n",
        "print(\"\\n📈 Min-Max Normalization Visualization:\")\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "axes = axes.ravel()\n",
        "\n",
        "for idx, col in enumerate(numerical_features):\n",
        "    axes[idx].hist(df_minmax[f'{col}_minmax'], bins=30, color='skyblue', edgecolor='black', alpha=0.7)\n",
        "    axes[idx].set_title(f'Min-Max: {col}', fontsize=12, fontweight='bold')\n",
        "    axes[idx].set_xlabel('Normalized Value')\n",
        "    axes[idx].set_ylabel('Frequency')\n",
        "    axes[idx].axvline(df_minmax[f'{col}_minmax'].mean(), color='red', linestyle='--', linewidth=2)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Z-Score Normalization\n",
        "print(\"\\n\" + \"-\"*80)\n",
        "print(\"4.2 Z-SCORE NORMALIZATION (Standardization)\")\n",
        "print(\"-\"*80)\n",
        "\n",
        "scaler_zscore = StandardScaler()\n",
        "df_zscore = pd.DataFrame(\n",
        "    scaler_zscore.fit_transform(df_norm),\n",
        "    columns=[f'{col}_zscore' for col in numerical_features]\n",
        ")\n",
        "\n",
        "print(\"\\n✅ Z-Score Normalized Data:\")\n",
        "print(df_zscore.describe())\n",
        "\n",
        "print(\"\\n📈 Z-Score Normalization Visualization:\")\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "axes = axes.ravel()\n",
        "\n",
        "for idx, col in enumerate(numerical_features):\n",
        "    axes[idx].hist(df_zscore[f'{col}_zscore'], bins=30, color='coral', edgecolor='black', alpha=0.7)\n",
        "    axes[idx].set_title(f'Z-Score: {col}', fontsize=12, fontweight='bold')\n",
        "    axes[idx].set_xlabel('Standardized Value')\n",
        "    axes[idx].set_ylabel('Frequency')\n",
        "    axes[idx].axvline(0, color='red', linestyle='--', linewidth=2, label='Mean = 0')\n",
        "    axes[idx].legend()\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n📊 Comparison: Min-Max vs Z-Score\")\n",
        "comparison_data = {\n",
        "    'Method': ['Min-Max', 'Z-Score'],\n",
        "    'Range': ['[0, 1]', 'Unbounded (usually -3 to +3)'],\n",
        "    'Mean': [df_minmax.mean().mean(), df_zscore.mean().mean()],\n",
        "    'Std Dev': [df_minmax.std().mean(), df_zscore.std().mean()],\n",
        "    'Use Case': ['Neural Networks, Image Processing', 'PCA, Algorithms sensitive to scale']\n",
        "}\n",
        "comparison_df = pd.DataFrame(comparison_data)\n",
        "print(comparison_df.to_string(index=False))\n",
        "\n",
        "# ==========================================\n",
        "# TASK 5: PCA (CONDITIONAL)\n",
        "# ==========================================\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"TASK 5: PRINCIPAL COMPONENT ANALYSIS (PCA)\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "print(\"\\n📊 Step 1: Check Correlation Matrix\")\n",
        "correlation = df_norm.corr()\n",
        "print(correlation)\n",
        "\n",
        "print(\"\\n🔥 Correlation Heatmap:\")\n",
        "plt.figure(figsize=(10, 8))\n",
        "sns.heatmap(correlation, annot=True, fmt='.3f', cmap='coolwarm', center=0,\n",
        "            square=True, linewidths=2, cbar_kws={\"shrink\": 0.8})\n",
        "plt.title('Feature Correlation Matrix', fontsize=16, fontweight='bold')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "high_corr = []\n",
        "for i in range(len(correlation.columns)):\n",
        "    for j in range(i+1, len(correlation.columns)):\n",
        "        if abs(correlation.iloc[i, j]) > 0.3:\n",
        "            high_corr.append((correlation.columns[i], correlation.columns[j], correlation.iloc[i, j]))\n",
        "\n",
        "print(\"\\n✅ Correlations > 0.3:\")\n",
        "if high_corr:\n",
        "    for feat1, feat2, corr_val in high_corr:\n",
        "        print(f\"  {feat1} ↔ {feat2}: {corr_val:.3f}\")\n",
        "\n",
        "    print(\"\\n🎯 Correlation exists! Applying PCA...\")\n",
        "\n",
        "    print(\"\\n\" + \"-\"*80)\n",
        "    print(\"Step 2: Apply PCA\")\n",
        "    print(\"-\"*80)\n",
        "\n",
        "    pca = PCA()\n",
        "    pca_data = pca.fit_transform(scaler_zscore.fit_transform(df_norm))\n",
        "\n",
        "    explained_variance = pca.explained_variance_ratio_\n",
        "    cumulative_variance = np.cumsum(explained_variance)\n",
        "\n",
        "    print(\"\\n📊 Explained Variance by Component:\")\n",
        "    for i, (exp_var, cum_var) in enumerate(zip(explained_variance, cumulative_variance)):\n",
        "        print(f\"  PC{i+1}: {exp_var*100:.2f}% (Cumulative: {cum_var*100:.2f}%)\")\n",
        "\n",
        "    print(\"\\n📈 Scree Plot:\")\n",
        "    plt.figure(figsize=(10, 6))\n",
        "    plt.plot(range(1, len(explained_variance)+1), explained_variance, 'bo-', linewidth=2, markersize=8)\n",
        "    plt.plot(range(1, len(cumulative_variance)+1), cumulative_variance, 'rs--', linewidth=2, markersize=8)\n",
        "    plt.xlabel('Principal Component', fontsize=12)\n",
        "    plt.ylabel('Variance Explained', fontsize=12)\n",
        "    plt.title('PCA Scree Plot', fontsize=16, fontweight='bold')\n",
        "    plt.legend(['Individual Variance', 'Cumulative Variance'])\n",
        "    plt.grid(alpha=0.3)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    n_components = np.argmax(cumulative_variance >= 0.95) + 1\n",
        "    print(f\"\\n✅ Components needed for 95% variance: {n_components}\")\n",
        "\n",
        "    pca_final = PCA(n_components=n_components)\n",
        "    pca_transformed = pca_final.fit_transform(scaler_zscore.fit_transform(df_norm))\n",
        "\n",
        "    pca_df = pd.DataFrame(\n",
        "        pca_transformed,\n",
        "        columns=[f'PC{i+1}' for i in range(n_components)]\n",
        "    )\n",
        "\n",
        "    print(f\"\\n📊 PCA Reduced Data Shape: {pca_df.shape}\")\n",
        "    print(f\"Original features: {len(numerical_features)} → Reduced to: {n_components}\")\n",
        "    print(f\"Dimension reduction: {((len(numerical_features)-n_components)/len(numerical_features)*100):.1f}%\")\n",
        "\n",
        "    print(\"\\n📊 First 5 rows of PCA-transformed data:\")\n",
        "    print(pca_df.head())\n",
        "\n",
        "    if n_components >= 2:\n",
        "        print(\"\\n📍 PCA 2D Visualization:\")\n",
        "        plt.figure(figsize=(10, 8))\n",
        "        scatter = plt.scatter(pca_df['PC1'], pca_df['PC2'],\n",
